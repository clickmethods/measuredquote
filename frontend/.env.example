# Google Maps JS API key — MUST be referrer-restricted in Google Cloud Console
# (the old key was hardcoded in source and should be rotated)
VITE_MAPS_API_KEY=

# Base URL for Netlify functions. Empty = same origin (production).
# For local dev against a deployed backend: https://app.measuredquote.com
VITE_API_BASE=

# Supabase (used by the MeasuredQuote platform pieces when merged in)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
