# =============================================================================
# MeasuredQuote — example environment file
# =============================================================================
# Copy this to `.env` for local development (Express server) or set the
# matching variables under "Site settings > Environment variables" in Netlify
# for production. NEVER commit a real `.env` file.
#
# Three categories:
#   1. Client (Vite) — prefixed with VITE_, embedded into the browser bundle.
#      ONLY put values here that are safe for any visitor to see.
#   2. Server (Express) — used by `server/index.ts` in dev/local prod.
#   3. Netlify Functions — only loaded by code under `netlify/functions/*`.

# -----------------------------------------------------------------------------
# 1. Client (safe for browser bundle)
# -----------------------------------------------------------------------------
VITE_APP_URL=http://localhost:5000
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Optional: enables the Stripe.js redirect helper (Checkout sessions don't
# strictly need it because we receive a hosted URL, but keep it ready for
# future Stripe Elements integration).
VITE_STRIPE_PUBLISHABLE_KEY=
# Optional: the browser Google Maps JS API key. The app stays on the
# simulated map when this is empty.
VITE_GOOGLE_MAPS_BROWSER_KEY=

# -----------------------------------------------------------------------------
# 2. Server (Express, local + bundled Lambda when running locally)
# -----------------------------------------------------------------------------
PORT=5000
NODE_ENV=development
# Used by `server/webhooks.ts` to sign delivered payloads when no per-
# integration secret is set. Rotate quarterly in production.
WEBHOOK_SIGNING_PEPPER=

# -----------------------------------------------------------------------------
# 3. Netlify Functions (server-only secrets — never expose to browser)
# -----------------------------------------------------------------------------
APP_URL=https://app.measuredquote.com
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=

# Google Maps server key (for any server-side geocoding; restricted by IP).
GOOGLE_MAPS_SERVER_KEY=
